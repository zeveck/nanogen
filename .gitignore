.zskills/tracking/
.test-results.txt
.playwright/output/

# API key — never commit. /nanogen (and many other tools) reads
# GEMINI_API_KEY from a local .env file at the repo root.
.env

# Worktree-landing markers (zskills convention). These belong INSIDE a
# worktree path where cleanup tools read them to decide whether a
# worktree's commits have been cherry-picked to main. A .landed at the
# repo root is a misapplication of the convention — but ignoring here
# prevents accidental commits in case something writes one.
.landed

# Generated images + history (matches imagegen's convention). SKILL.md
# routes /nanogen outputs under assets/<category>/; those are per-user
# disposable artifacts, not source-controlled. Commit source images
# intentionally via `git add -f assets/...` if you need to version a
# specific input.
assets/
.nanogen-history.jsonl

# Claude Code session artifacts. scheduled_tasks.lock holds the
# sessionId + PID that owns the in-memory cron scheduler; tied to
# a single Claude process, meaningless across sessions.
.claude/scheduled_tasks.lock
