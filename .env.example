# nanogen environment configuration
#
# Copy to .env in this directory (or in any parent directory of where you
# run nanogen — the CLI walks upward to find one). The .env file is loaded
# automatically; you don't need to source it.

# ── Required ─────────────────────────────────────────────────────────────
# Your Gemini API key. Get one at https://aistudio.google.com/app/apikey.
# GOOGLE_API_KEY is accepted as a fallback if GEMINI_API_KEY is unset.
GEMINI_API_KEY=

# ── Optional: which Gemini model nanogen uses ────────────────────────────
# By default nanogen generates images with Flash. To upgrade to Pro for
# every generation, uncomment the line below. Cost shown is per 1K image:
#
#   flash        — Nano Banana 2     $0.067   [default — best cost/quality]
#   pro          — Nano Banana Pro   $0.134   (2× Flash; small edge on
#                                              fringe-sensitive subjects
#                                              like vector edges and text)
#   flash-stable — Nano Banana (GA)  $0.039   (older, less prompt fidelity)
#
# NANOGEN_MODEL=pro

# ── Optional: test/development knobs ─────────────────────────────────────
# Override the API base URL. Used by integration tests to point at a local
# mock server. Leave unset in normal use.
# NANOGEN_API_BASE=https://generativelanguage.googleapis.com

# Retry tuning (rarely changed):
# NANOGEN_MAX_RETRIES=3
# NANOGEN_RETRY_BASE_MS=1000
# NANOGEN_FETCH_TIMEOUT_MS=120000
