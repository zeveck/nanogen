# nanogen environment configuration
#
# Copy to .env in this directory (or in any parent directory of where you
# run nanogen — the CLI walks upward to find one). The .env file is loaded
# automatically; you don't need to source it.

# ── Required ─────────────────────────────────────────────────────────────
# Your Gemini API key. Get one at https://aistudio.google.com/app/apikey.
# GOOGLE_API_KEY is accepted as a fallback if GEMINI_API_KEY is unset.
GEMINI_API_KEY=

# ── Optional: default model ──────────────────────────────────────────────
# Override the default model nanogen reaches for when --model is not passed.
# Accepts aliases or full model names. To see what your key approves, run:
#
#     nanogen --list-models
#
# Aliases (cost shown for 1K image output):
#   flash        → gemini-3.1-flash-image-preview (Nano Banana 2)   $0.067 [default]
#   pro          → gemini-3-pro-image-preview    (Nano Banana Pro) $0.134  (2× Flash)
#   flash-stable → gemini-2.5-flash-image         (Nano Banana, GA) $0.039
#
# Default is `flash` — best quality-to-cost ratio for most subjects. Pro
# has a small visible edge on fringe-sensitive work (vector edges, fluffy
# fur, embedded text). Set the env var below to make Pro the default
# everywhere without retyping --model on every call.
# NANOGEN_MODEL=pro

# ── Optional: test/development knobs ─────────────────────────────────────
# Override the API base URL. Used by integration tests to point at a local
# mock server. Leave unset in normal use.
# NANOGEN_API_BASE=https://generativelanguage.googleapis.com

# Retry tuning (rarely changed):
# NANOGEN_MAX_RETRIES=3
# NANOGEN_RETRY_BASE_MS=1000
# NANOGEN_FETCH_TIMEOUT_MS=120000
